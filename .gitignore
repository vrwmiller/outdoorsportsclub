# =============================================================================
# SECRETS & CREDENTIALS — must never be committed
# =============================================================================
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# AWS
.aws/
aws-exports.js
amplifyconfiguration.json
amplifyconfiguration.ts
amplify_outputs.json

# Stripe
stripe_*.json

# =============================================================================
# PII & DATA EXPORTS — must never be committed
# =============================================================================
*.csv
*.sql
*.dump
*.bak
data-exports/
member-data/
# Schema migration files are not PII — allow them explicitly.
!db/migrations/*.sql

# =============================================================================
# NEXT.JS
# =============================================================================
.next/
out/
build/
dist/

# =============================================================================
# NODE / NPM
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js
.yarn/install-state.gz
package-lock.json.bak

# =============================================================================
# PYTHON / AWS LAMBDA
# =============================================================================
.ruff_cache/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
*.coverage
.coverage
htmlcov/

# Lambda deployment packages
*.zip

# =============================================================================
# AWS AMPLIFY
# =============================================================================
# amplify/ contains committed Amplify Gen 2 source (backend.ts) — track the directory.
# Ignore only generated/runtime outputs from the Amplify Gen 2 toolchain.
amplify_outputs.json
amplify/.amplify/
amplify/#current-cloud-backend/
.amplify/

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
Desktop.ini

# =============================================================================
# EDITORS & IDEs
# =============================================================================
.idea/
*.swp
*.swo
*~

# =============================================================================
# LOGS & DIAGNOSTICS
# =============================================================================
logs/
*.log
*.log.*
