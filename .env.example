# .env.example
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file containing real values.
# All values marked REQUIRED must be set before the application will start.

# =============================================================================
# AWS — General
# =============================================================================
AWS_REGION=us-east-1

# =============================================================================
# AWS Amplify / API
# =============================================================================
# Base URL of the deployed API Gateway stage (no trailing slash)
# e.g. https://abc123.execute-api.us-east-1.amazonaws.com/prod
NEXT_PUBLIC_API_BASE_URL=                         # REQUIRED

# =============================================================================
# AWS Cognito — Member Auth (website)
# =============================================================================
NEXT_PUBLIC_COGNITO_REGION=us-east-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=                 # REQUIRED  e.g. us-east-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_APP_CLIENT_ID=                # REQUIRED  e.g. 1a2b3c4d5e...
NEXT_PUBLIC_COGNITO_DOMAIN=                       # REQUIRED  e.g. osc-auth.auth.us-east-1.amazoncognito.com
# Redirect URLs must be registered in the Cognito App Client settings
NEXT_PUBLIC_COGNITO_REDIRECT_SIGN_IN=http://localhost:3000/auth/callback
NEXT_PUBLIC_COGNITO_REDIRECT_SIGN_OUT=http://localhost:3000

# =============================================================================
# Kiosk — Device Token (Kiosk View only; do NOT expose on member/admin pages)
# =============================================================================
# Set on kiosk tablets only — leave blank on developer machines and CI
NEXT_PUBLIC_DEVICE_TOKEN=                         # REQUIRED on kiosk tablets

# =============================================================================
# Lambda environment variables (set in CloudFormation / Amplify Gen 2 backend)
# These are NOT NEXT_PUBLIC — they are server-side only.
# Include here for reference so IaC knows what to provision.
# =============================================================================
DB_CLUSTER_ARN=                                   # Aurora cluster ARN
DB_SECRET_ARN=                                    # Secrets Manager ARN for DB credentials
DB_NAME=outdoorsportsclub

COGNITO_USER_POOL_ID=                             # Same pool as above — used server-side for JWT validation
COGNITO_REGION=us-east-1

STRIPE_SECRET_ARN=                                # Secrets Manager ARN for Stripe secret key

S3_WAIVER_BUCKET=                                 # S3 bucket name for signed waivers

SNS_ALERTS_TOPIC_ARN=                             # SNS topic ARN for range alerts

CORS_ALLOW_ORIGIN=http://localhost:3000           # Set to the real domain in production
